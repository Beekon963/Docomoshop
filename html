<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ドコモ店内研修教材｜2026年3月29日版</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=M+PLUS+Rounded+1c:wght@400;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --red: #E60033;
  --red-dark: #C4002B;
  --red-light: #FFF0F3;
  --gold: #B8860B;
  --gold-light: #FFF8E7;
  --blue: #0068B7;
  --blue-light: #EBF5FF;
  --green: #00A960;
  --green-light: #EEFFF5;
  --orange: #FF6600;
  --orange-light: #FFF4EB;
  --purple: #6B3FA0;
  --purple-light: #F5EEFF;
  --gray-50: #FAFAFA;
  --gray-100: #F5F5F5;
  --gray-200: #E8E8E8;
  --gray-300: #D0D0D0;
  --gray-600: #666;
  --gray-800: #333;
  --gray-900: #1A1A1A;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
  --radius: 12px;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Noto Sans JP’, sans-serif;
background: var(–gray-50);
color: var(–gray-800);
line-height: 1.7;
font-size: 15px;
}

/* ===== HEADER ===== */
.header {
background: linear-gradient(135deg, var(–red) 0%, var(–red-dark) 100%);
color: #fff;
padding: 20px 24px;
position: sticky;
top: 0;
z-index: 100;
box-shadow: 0 4px 20px rgba(230,0,51,0.3);
}
.header-inner {
max-width: 1200px;
margin: 0 auto;
display: flex;
align-items: center;
justify-content: space-between;
flex-wrap: wrap;
gap: 8px;
}
.header h1 {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 22px;
font-weight: 800;
letter-spacing: 1px;
}
.header .date-badge {
background: rgba(255,255,255,0.2);
padding: 4px 14px;
border-radius: 20px;
font-size: 13px;
font-weight: 500;
backdrop-filter: blur(4px);
}

/* ===== TAB NAV ===== */
.tab-nav {
background: #fff;
border-bottom: 1px solid var(–gray-200);
position: sticky;
top: 68px;
z-index: 99;
overflow-x: auto;
-webkit-overflow-scrolling: touch;
scrollbar-width: none;
}
.tab-nav::-webkit-scrollbar { display: none; }
.tab-nav-inner {
max-width: 1200px;
margin: 0 auto;
display: flex;
gap: 0;
min-width: max-content;
}
.tab-btn {
padding: 14px 20px;
border: none;
background: none;
font-family: ‘Noto Sans JP’, sans-serif;
font-size: 13px;
font-weight: 500;
color: var(–gray-600);
cursor: pointer;
white-space: nowrap;
border-bottom: 3px solid transparent;
transition: all 0.2s;
}
.tab-btn:hover { color: var(–red); background: var(–red-light); }
.tab-btn.active {
color: var(–red);
border-bottom-color: var(–red);
font-weight: 700;
}

/* ===== CONTENT ===== */
.content {
max-width: 1200px;
margin: 0 auto;
padding: 24px;
}
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* ===== COMMON COMPONENTS ===== */
.section-title {
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 20px;
font-weight: 800;
margin: 32px 0 16px;
padding-left: 16px;
border-left: 5px solid var(–red);
line-height: 1.4;
}
.section-title:first-child { margin-top: 0; }

.card {
background: #fff;
border-radius: var(–radius);
box-shadow: var(–shadow);
padding: 24px;
margin-bottom: 20px;
}
.card-accent {
border-top: 4px solid var(–red);
}

/* Tables */
.price-table {
width: 100%;
border-collapse: collapse;
margin: 12px 0;
font-size: 14px;
}
.price-table th {
background: var(–gray-900);
color: #fff;
padding: 10px 12px;
text-align: left;
font-weight: 700;
font-size: 13px;
}
.price-table td {
padding: 10px 12px;
border-bottom: 1px solid var(–gray-200);
}
.price-table tr:nth-child(even) td { background: var(–gray-50); }
.price-table .highlight { color: var(–red); font-weight: 700; }
.price-table .small { font-size: 11px; color: var(–gray-600); display: block; }
.price-table .price-big {
font-size: 20px;
font-weight: 900;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
}

/* Talk Script */
.talk-box {
background: var(–blue-light);
border-radius: var(–radius);
padding: 20px;
margin: 16px 0;
border-left: 5px solid var(–blue);
}
.talk-box.customer {
background: var(–orange-light);
border-left-color: var(–orange);
}
.talk-box .label {
font-size: 12px;
font-weight: 700;
text-transform: uppercase;
margin-bottom: 6px;
letter-spacing: 1px;
}
.talk-box .label.staff { color: var(–blue); }
.talk-box .label.customer-label { color: var(–orange); }
.talk-box p { font-size: 14px; line-height: 1.8; }
.talk-box .point {
background: #fff;
border-radius: 8px;
padding: 10px 14px;
margin-top: 10px;
font-size: 13px;
color: var(–gray-600);
border: 1px dashed var(–gray-300);
}
.talk-box .point::before {
content: “💡 ポイント：”;
font-weight: 700;
color: var(–gold);
}

/* Flow */
.flow-step {
display: flex;
gap: 16px;
margin: 16px 0;
align-items: flex-start;
}
.flow-num {
width: 40px;
height: 40px;
min-width: 40px;
background: var(–red);
color: #fff;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-weight: 900;
font-size: 16px;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
}
.flow-content h4 {
font-size: 16px;
font-weight: 700;
margin-bottom: 4px;
}
.flow-content p { font-size: 14px; color: var(–gray-600); }

/* Badge */
.badge {
display: inline-block;
padding: 2px 10px;
border-radius: 12px;
font-size: 11px;
font-weight: 700;
margin: 0 4px 4px 0;
}
.badge-red { background: var(–red-light); color: var(–red); }
.badge-blue { background: var(–blue-light); color: var(–blue); }
.badge-green { background: var(–green-light); color: var(–green); }
.badge-gold { background: var(–gold-light); color: var(–gold); }
.badge-purple { background: var(–purple-light); color: var(–purple); }
.badge-orange { background: var(–orange-light); color: var(–orange); }

/* Checklist */
.checklist { list-style: none; padding: 0; }
.checklist li {
padding: 8px 0 8px 28px;
position: relative;
font-size: 14px;
border-bottom: 1px solid var(–gray-100);
}
.checklist li::before {
content: “✓”;
position: absolute;
left: 0;
color: var(–green);
font-weight: 900;
font-size: 16px;
}

/* Roleplay */
.roleplay {
background: linear-gradient(135deg, #FFFDF5 0%, #FFF8E7 100%);
border: 2px solid var(–gold);
border-radius: var(–radius);
padding: 20px;
margin: 16px 0;
}
.roleplay h4 {
color: var(–gold);
font-size: 14px;
font-weight: 700;
margin-bottom: 12px;
}
.roleplay .scenario {
background: #fff;
border-radius: 8px;
padding: 14px;
margin-bottom: 12px;
border: 1px solid #EDD;
font-size: 13px;
}

/* Grid for summary */
.grid-2 {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
}
@media (max-width: 768px) {
.grid-2 { grid-template-columns: 1fr; }
.header h1 { font-size: 18px; }
.tab-btn { padding: 12px 14px; font-size: 12px; }
.content { padding: 16px; }
.price-table { font-size: 12px; }
.price-table .price-big { font-size: 16px; }
}

/* Connector arrow between talk boxes */
.arrow-down {
text-align: center;
font-size: 24px;
color: var(–gray-300);
margin: 4px 0;
}

/* Highlight box */
.highlight-box {
background: var(–red-light);
border: 2px solid var(–red);
border-radius: var(–radius);
padding: 16px 20px;
margin: 16px 0;
font-size: 14px;
}
.highlight-box strong { color: var(–red); }

/* Print support */
@media print {
.header, .tab-nav { position: static; }
.tab-panel { display: block !important; page-break-before: always; }
}
</style>

</head>
